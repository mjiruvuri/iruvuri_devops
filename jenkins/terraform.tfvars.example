aws_region          = "us-east-1"
ami_id              = "ami-0c7217cdde317cfec"   # Ubuntu 22.04 LTS us-east-1 — verify latest at https://cloud-images.ubuntu.com/locator/ec2/
instance_type       = "t3.medium"
spot_max_price      = "0.02"                    # ~$14/mo cap; on-demand is ~$0.0416/hr
allowed_cidr        = "YOUR_IP/32"              # replace with your public IP
state_bucket_name   = "your-unique-tfstate-bucket-name"
lock_table_name     = "terraform-locks"
root_volume_size_gb = 20
# key_name          = "your-key-pair-name"      # optional; omit to use SSM Session Manager
